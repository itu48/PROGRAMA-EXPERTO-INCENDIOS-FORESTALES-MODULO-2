TEMPORAL

// 1. Cargar colección de focos de calor de MODIS (Terra)
var fireEvents = ee.ImageCollection("MODIS/061/MYD14A1")
    .filterDate('2023-08-31', '2023-09-01');

// 2. Seleccionar la banda correcta: FireMask
// Valores: 7 (Baja conf), 8 (Nominal), 9 (Alta conf)
var fireVis = fireEvents.select('FireMask').max();

// 3. Visualización
var fireParams = {
  min: 7, 
  max: 9, 
  palette: ['yellow', 'orange', 'red']
};

Map.setCenter(-62.0, -16.0, 6);
Map.addLayer(fireVis, fireParams, 'Focos de Calor MODIS (Agosto 2023)');

print('Resolución Temporal: Noten cómo MODIS detecta el evento diario a nivel regional.');
