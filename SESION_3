/**
 * COMPARACIÓN TEMPORAL MULTISATÉLITE
 * Área: Chiquitanía, Bolivia (Temporada crítica de incendios 2023)
 */

var area = ee.Geometry.Point([-60.7, -16.2]);
var inicio = '2023-08-01';
var fin = '2023-08-31';

Map.centerObject(area, 10);

// 1. MODIS (Terra & Aqua combinado) - Resolución: 250m-1km / Frecuencia: DIARIA
var modis = ee.ImageCollection("MODIS/061/MOD09GA")
  .filterBounds(area).filterDate(inicio, fin);

// 2. VIIRS (Suomi NPP) - Resolución: 375m-750m / Frecuencia: DIARIA (Gran capacidad térmica)
var viirs = ee.ImageCollection("NOAA/VIIRS/001/VNP09GA")
  .filterBounds(area).filterDate(inicio, fin);

// 3. SENTINEL-2 (A & B) - Resolución: 10m-20m / Frecuencia: ~5 DÍAS
var s2 = ee.ImageCollection("COPERNICUS/S2_SR_HARMONIZED")
  .filterBounds(area).filterDate(inicio, fin);

// 4. LANDSAT (8 & 9 combinado) - Resolución: 30m / Frecuencia: ~8 DÍAS
var landsat = ee.ImageCollection("LANDSAT/LC08/C02/T1_L2")
  .merge(ee.ImageCollection("LANDSAT/LC09/C02/T1_L2"))
  .filterBounds(area).filterDate(inicio, fin);

// RESULTADOS EN CONSOLA
print('--- DISPONIBILIDAD EN 1 MES (AGOSTO 2023) ---');
print('MODIS (Diario):', modis.size());
print('VIIRS (Diario):', viirs.size());
print('Sentinel-2 (5 días):', s2.size());
print('Landsat 8+9 (8 días):', landsat.size());
