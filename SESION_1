ESPECTRAL

// 1. Ubicación de un incendio forestal
Map.setCenter(-62.15, -15.55, 12); 

// 2. Imagen con presencia de humo
var image = ee.ImageCollection("COPERNICUS/S2_SR_HARMONIZED")
    .filterBounds(Map.getCenter())
    .filterDate('2023-09-01', '2023-10-15')
    .sort('CLOUDY_PIXEL_PERCENTAGE')
    .first();

// 3. Capa 1: Color Real (Vemos el humo blanco)
Map.addLayer(image, {bands: ['B4', 'B3', 'B2'], min: 0, max: 3000}, '1. Color Real (Ojo Humano)');

// 4. Capa 2: Falso Color (SWIR - Atraviesa el humo y resalta el fuego)
// B12: SWIR 2, B8: NIR, B4: Rojo
Map.addLayer(image, {bands: ['B12', 'B8', 'B4'], min: 0, max: 4000}, '2. SWIR (Penetración de Humo)');

print('Resolución Espectral: Cambien entre capas para ver cómo las bandas infrarrojas revelan el suelo quemado bajo el humo.');
