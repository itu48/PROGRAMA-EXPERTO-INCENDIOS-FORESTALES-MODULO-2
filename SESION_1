COMPARATIVA RESOLUCION ESPACIAL Y ESPECTRAL
ESPACIAL

// 1. Definir ubicación
var lon = -63.18;
var lat = -17.78; 
Map.setCenter(lon, lat, 14);

// 2. Sentinel-2 
var s2 = ee.ImageCollection("COPERNICUS/S2_SR_HARMONIZED")
    .filterBounds(Map.getCenter())
    .filterDate('2023-01-01', '2023-12-31')
    .sort('CLOUDY_PIXEL_PERCENTAGE')
    .first();

// 3.MODIS
var modis = ee.ImageCollection("MODIS/061/MOD09GQ")
    .filterDate('2023-01-01', '2023-12-31')
    .first();

// 4. Visualización
Map.addLayer(s2, {bands: ['B4', 'B3', 'B2'], min: 0, max: 3000}, 'Sentinel-2 (10m)');
Map.addLayer(modis, {bands: ['sur_refl_b01', 'sur_refl_b02', 'sur_refl_b01'], min: 0, max: 3000}, 'MODIS (250m)');

print('Carga con exito');
