/**
 * CASO 5: TÉRMICO CON INSPECTOR INTEGRADO
 */
var incendioActivo = ee.Geometry.Point([-59.12, -18.25]);
Map.centerObject(incendioActivo, 12);

var l8_tirs = ee.ImageCollection("LANDSAT/LC08/C02/T1_L2")
  .filterBounds(incendioActivo)
  .filterDate('2023-09-01', '2023-10-15')
  .sort('CLOUD_COVER')
  .first();

var tempC = l8_tirs.select('ST_B10')
  .multiply(0.00341802)
  .add(149.0)
  .subtract(273.15);

Map.addLayer(tempC, {
  min: 25, 
  max: 65, 
  palette: ['blue', 'yellow', 'orange', 'red']
}, 'Temperatura de Superficie (°C)');

// --- 1. RESULTADO  ---
var inspector = ui.Panel({
  style: {position: 'top-right', width: '200px'}
});
inspector.add(ui.Label('Haz clic en el mapa', {color: 'gray'}));
Map.add(inspector);

// --- 2. CONFIGURACIÓN DEL CURSOR Y EVENTO CLICK ---
Map.style().set('cursor', 'crosshair');

Map.onClick(function(coords) {
  // Limpiar el panel antes de mostrar nuevo resultado
  inspector.clear();
  inspector.add(ui.Label('Cargando...', {color: 'gray'}));
  
  var punto = ee.Geometry.Point(coords.lon, coords.lat);
  
  // Obtener el valor
  var muestra = tempC.reduceRegion({
    reducer: ee.Reducer.first(),
    geometry: punto,
    scale: 30
  });
  
  // Usar evaluate para que la interfaz no se congele
  muestra.evaluate(function(resultado) {
    inspector.clear();
    var tempVal = resultado.ST_B10;
    
    if (tempVal !== null) {
      inspector.add(ui.Label({
        value: 'Temp: ' + tempVal.toFixed(2) + ' °C',
        style: {fontWeight: 'bold', fontSize: '18px', color: 'red'}
      }));
      inspector.add(ui.Label('Lat: ' + coords.lat.toFixed(4)));
      inspector.add(ui.Label('Lon: ' + coords.lon.toFixed(4)));
    } else {
      inspector.add(ui.Label('Sin datos en este punto'));
    }
  });
});

// --- 3. LEYENDA  ---
var leyenda = ui.Panel({style: {position: 'bottom-left', padding: '8px'}});
leyenda.add(ui.Label('Temperatura (°C)', {fontWeight: 'bold'}));
